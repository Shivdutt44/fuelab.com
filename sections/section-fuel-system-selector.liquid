{%- liquid
  assign filter_blocks = section.blocks | where: 'type', 'filter'
  assign accent = section.settings.accent_color
  assign bg_image = section.settings.background_image
-%}

<div
  class="fss"
  id="fss-{{ section.id }}"
  data-search-url="{{ section.settings.search_url }}"
  style="
    --fss-accent: {{ accent }};
    --fss-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --fss-search-btn-color: {{ section.settings.search_btn_text_color }};
    --fss-search-btn-size: {{ section.settings.search_btn_font_size }}px;
    --fss-calc-btn-color: {{ section.settings.calc_btn_text_color }};
    --fss-calc-btn-size: {{ section.settings.calc_btn_font_size }}px;
    --fss-bar-padding: {{ section.settings.bar_padding }}px;
    --fss-btn-padding-x: {{ section.settings.btn_padding_x }}px;
    --fss-hero-padding-top: {{ section.settings.hero_padding_top }}px;
    --fss-hero-padding-bottom: {{ section.settings.hero_padding_bottom }}px;
    --fss-calc-padding: {{ section.settings.calc_padding }}px;
  "
>
  <div class="fss__hero">
    {%- if bg_image != blank -%}
      <img
        class="fss__hero-image"
        src="{{ bg_image | image_url: width: 2400 }}"
        srcset="{{ bg_image | image_url: width: 1200 }} 1200w, {{ bg_image | image_url: width: 1800 }} 1800w, {{ bg_image | image_url: width: 2400 }} 2400w"
        alt="{{ bg_image.alt | escape }}"
        loading="lazy"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
      >
    {%- endif -%}
    <div class="fss__hero-overlay"></div>

    {%- if section.settings.heading != blank -%}
      <h2 class="fss__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="fss__bar">
      <div class="fss__fields">
        {%- for block in filter_blocks -%}
          {%- liquid
            assign options = block.settings.options | newline_to_br | strip_newlines | split: '<br />'
          -%}
          <div class="fss__field" {{ block.shopify_attributes }}>
            <select
              class="fss__select"
              data-filter-param="{{ block.settings.param | default: block.id }}"
              aria-label="{{ block.settings.label }}"
            >
              <option value="">{{ block.settings.label }}</option>
              {%- for option in options -%}
                {%- assign option = option | strip -%}
                {%- if option != blank -%}
                  <option value="{{ option }}">{{ option }}</option>
                {%- endif -%}
              {%- endfor -%}
            </select>
          </div>
        {%- endfor -%}
      </div>

      <div class="fss__actions">
        <button type="button" class="fss__search-btn" data-fss-search>
          {{ section.settings.search_label | default: 'Search' }}
        </button>
        <button type="button" class="fss__reset-btn" data-fss-reset aria-label="{{ section.settings.reset_label | default: 'Reset filters' }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="20" height="20" fill="currentColor">
            <path d="M440.65 12.57l4 82.77A247.16 247.16 0 0 0 255.83 8C134.73 8 33.91 94.92 12.29 209.82A12 12 0 0 0 24.09 224h49.05a12 12 0 0 0 11.67-9.26 175.91 175.91 0 0 1 317-56.94l-101.46-4.86a12 12 0 0 0-12.57 12v47.41a12 12 0 0 0 12 12H500a12 12 0 0 0 12-12V12a12 12 0 0 0-12-12h-47.37a12 12 0 0 0-11.98 12.57zM255.83 432a175.61 175.61 0 0 1-146-77.8l101.8 4.87a12 12 0 0 0 12.57-12v-47.4a12 12 0 0 0-12-12H12a12 12 0 0 0-12 12V500a12 12 0 0 0 12 12h47.35a12 12 0 0 0 12-12.6l-4.15-82.57A247.17 247.17 0 0 0 255.83 504c121.11 0 221.93-86.92 243.55-201.82a12 12 0 0 0-11.8-14.18h-49.05a12 12 0 0 0-11.67 9.26A175.86 175.86 0 0 1 255.83 432z"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  {%- if section.settings.show_calculator -%}
    <div class="fss__calc">
      <div class="fss__calc-inner">
        {%- if section.settings.calc_heading != blank -%}
          <h2 class="fss__calc-heading">{{ section.settings.calc_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.calc_subheading != blank -%}
          <p class="fss__calc-subheading">{{ section.settings.calc_subheading }}</p>
        {%- endif -%}
        {%- if section.settings.calc_button_text != blank -%}
          <a href="{{ section.settings.calc_button_url | default: '/pages/fuel-pump-calculator' }}" class="fss__calc-btn">
            <span>{{ section.settings.calc_button_text }}</span>
            <span class="fss__calc-btn-icon">
              <svg viewBox="0 0 24 24" width="10" height="10" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  #fss-{{ section.id }} {
    --fss-accent: #FFD204 !important; /* Force exact bright yellow accent from reference site */
    font-family: inherit;
  }
  #fss-{{ section.id }} .fss__hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--fss-hero-padding-top, 48px) 20px var(--fss-hero-padding-bottom, 70px);
    overflow: hidden;
    background: #0a0a0a;
    min-height: 280px;
  }
  #fss-{{ section.id }} .fss__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(35%);
    opacity: 0.55;
  }
  #fss-{{ section.id }} .fss__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.85) 100%);
    opacity: var(--fss-overlay, 0.8);
  }
  #fss-{{ section.id }} .fss__heading {
    position: relative;
    z-index: 2;
    color: var(--fss-accent);
    font-style: italic;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    text-align: center;
    font-size: clamp(22px, 4vw, 34px);
    margin: 0 0 28px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.6);
  }
  #fss-{{ section.id }} .fss__heading::before {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background: var(--fss-accent);
    margin: 0 auto 16px;
  }
  #fss-{{ section.id }} .fss__bar {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1240px;
    background: rgba(17, 17, 17, 0.85); /* Semi-transparent dark card */
    border: 1px solid rgba(255, 255, 255, 0.15); /* Thin grey border */
    border-radius: 0px; /* Sharp corners */
    padding: 15px !important; /* Even spacing around elements as in screenshot */
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  
  /* Infinite horizontal yellow lines running behind/outwards from the filter card */
  #fss-{{ section.id }} .fss__bar::before {
    content: '';
    position: absolute;
    top: 50%;
    right: 100%;
    width: 2000px;
    height: 2px;
    background: var(--fss-accent);
    z-index: -1;
    transform: translateY(-50%);
  }
  #fss-{{ section.id }} .fss__bar::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 100%;
    width: 2000px;
    height: 2px;
    background: var(--fss-accent);
    z-index: -1;
    transform: translateY(-50%);
  }

  #fss-{{ section.id }} .fss__fields {
    display: flex !important;
    flex: 1 !important;
    align-items: center !important;
    gap: 10px !important;
  }
  #fss-{{ section.id }} .fss__field {
    flex: 1 !important;
    min-width: 0 !important;
  }
  #fss-{{ section.id }} .fss__select {
    width: 100%;
    height: 46px;
    padding: 0 14px;
    border: 1px solid #dcdcdc !important; /* Subtle border outline */
    border-radius: 0px !important; /* Sharp corners */
    background: #ffffff;
    color: #333333;
    font-size: 14px;
    font-weight: 600;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none' stroke='%23333333' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='1 2 6 7 11 2'/></svg>") !important; /* Thin custom chevron */
    background-repeat: no-repeat;
    background-position: right 14px center;
    cursor: pointer;
  }
  #fss-{{ section.id }} .fss__actions {
    display: flex !important;
    gap: 10px !important;
    flex-shrink: 0 !important;
  }

  /* Reset button pseudo-elements to prevent global capsule styles from theme CSS */
  #fss-{{ section.id }} .fss__search-btn,
  #fss-{{ section.id }} .fss__reset-btn {
    float: none !important;
    margin: 0 !important;
    box-shadow: none !important;
    border: none !important;
    border-radius: 0px !important;
    min-width: 0 !important; /* Override theme min-width */
  }
  #fss-{{ section.id }} .fss__search-btn::before,
  #fss-{{ section.id }} .fss__search-btn::after,
  #fss-{{ section.id }} .fss__reset-btn::before,
  #fss-{{ section.id }} .fss__reset-btn::after {
    display: none !important;
    content: none !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }

  #fss-{{ section.id }} .fss__search-btn {
    height: 46px !important;
    padding: 0 var(--fss-btn-padding-x, 34px) !important;
    background: var(--fss-accent) !important;
    color: #111111 !important;
    border: none !important;
    border-radius: 0px !important;
    font-weight: 800 !important;
    text-transform: none !important; /* "Search" mixed-case as in screenshot */
    letter-spacing: normal !important;
    font-size: var(--fss-search-btn-size, 14px) !important;
    cursor: pointer !important;
    transition: background-color 0.2s ease !important;
  }
  #fss-{{ section.id }} .fss__search-btn:hover {
    background: #e6bd00 !important;
  }
  #fss-{{ section.id }} .fss__reset-btn {
    height: 46px !important;
    width: 46px !important;
    max-width: 46px !important;
    flex: 0 0 46px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background: transparent !important;
    color: var(--fss-accent) !important;
    border: 1px solid var(--fss-accent) !important;
    border-radius: 0px !important;
    cursor: pointer !important;
    padding: 0 !important;
    transition: transform 0.2s ease, opacity 0.2s ease !important;
  }
  #fss-{{ section.id }} .fss__reset-btn:hover {
    opacity: 0.85 !important;
  }
  #fss-{{ section.id }} .fss__reset-btn svg {
    width: 20px !important;
    height: 20px !important;
    fill: var(--fss-accent) !important;
    stroke: none !important;
  }

  #fss-{{ section.id }} .fss__calc {
    background: #000000;
    text-align: center;
    padding: var(--fss-calc-padding, 70px) 20px;
  }
  #fss-{{ section.id }} .fss__calc-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  #fss-{{ section.id }} .fss__calc-heading {
    color: var(--fss-accent);
    font-weight: 800;
    font-size: clamp(26px, 4vw, 40px);
    margin: 0 0 12px;
  }
  #fss-{{ section.id }} .fss__calc-subheading {
    color: #ffffff;
    font-size: 17px;
    margin: 0 0 30px;
    opacity: 0.9;
  }
  
  /* Reset pseudo-elements and style the Calculate Now button to match reference */
  #fss-{{ section.id }} .fss__calc-btn::before,
  #fss-{{ section.id }} .fss__calc-btn::after {
    display: none !important;
    content: none !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
  }
  #fss-{{ section.id }} .fss__calc-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 12px !important;
    background: var(--fss-accent) !important;
    color: #000000 !important;
    font-weight: 700 !important;
    text-transform: none !important;
    padding: 14px 28px !important;
    border-radius: 0px !important; /* Sharp corners */
    text-decoration: none !important;
    font-size: var(--fss-calc-btn-size, 17px) !important;
    line-height: 1 !important;
    float: none !important;
    margin: 0 auto !important;
    box-shadow: none !important;
    border: none !important;
    cursor: pointer !important;
    transition: background-color 0.2s ease !important;
  }
  #fss-{{ section.id }} .fss__calc-btn:hover {
    background: #e6bd00 !important;
  }
  #fss-{{ section.id }} .fss__calc-btn-icon {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 22px !important;
    height: 22px !important;
    background: #111111 !important; /* Dark circle background */
    color: var(--fss-accent) !important; /* Yellow arrow */
    border-radius: 50% !important;
  }
  #fss-{{ section.id }} .fss__calc-btn-icon svg {
    width: 10px !important;
    height: 10px !important;
  }

  @media only screen and (max-width: 991px) {
    #fss-{{ section.id }} .fss__bar {
      flex-direction: column !important;
      align-items: stretch !important;
    }
    #fss-{{ section.id }} .fss__bar::before,
    #fss-{{ section.id }} .fss__bar::after {
      display: none !important;
    }
    #fss-{{ section.id }} .fss__fields {
      display: grid !important;
      grid-template-columns: repeat(2, 1fr) !important; /* 2 columns on tablet */
      gap: 10px !important;
      width: 100% !important;
    }
    #fss-{{ section.id }} .fss__actions {
      display: flex !important;
      gap: 10px !important;
      width: 100% !important;
      margin-top: 10px !important;
    }
    #fss-{{ section.id }} .fss__search-btn {
      flex: 1 !important;
    }
    #fss-{{ section.id }} .fss__reset-btn {
      flex-shrink: 0 !important;
    }
  }
  @media only screen and (max-width: 575px) {
    #fss-{{ section.id }} .fss__fields {
      grid-template-columns: 1fr !important; /* 1 column on mobile */
    }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('fss-{{ section.id }}');
    if (!root) return;

    var searchBtn = root.querySelector('[data-fss-search]');
    var resetBtn = root.querySelector('[data-fss-reset]');
    var selects = root.querySelectorAll('.fss__select');
    var searchUrl = root.getAttribute('data-search-url') || '/search';

    if (searchBtn) {
      searchBtn.addEventListener('click', function () {
        var terms = [];
        selects.forEach(function (select) {
          if (select.value) {
            terms.push(select.value);
          }
        });
        if (!terms.length) return;
        var params = new URLSearchParams();
        params.set('q', terms.join(' '));
        params.set('type', 'product');
        window.location.href = searchUrl + '?' + params.toString();
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        selects.forEach(function (select) {
          select.selectedIndex = 0;
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Fuel system selector",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#f7c600"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Select Your Fuel System"
    },
    {
      "type": "url",
      "id": "search_url",
      "label": "Search results URL",
      "info": "Selected filter values are sent here as a native Shopify product search query (?q=...&type=product). Leave blank to use /search."
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search button label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "reset_label",
      "label": "Reset button accessible label",
      "default": "Reset filters"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "search_btn_text_color",
      "label": "Search button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "search_btn_font_size",
      "label": "Search button text size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "calc_btn_text_color",
      "label": "Calculate button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "calc_btn_font_size",
      "label": "Calculate button text size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "btn_padding_x",
      "label": "Button horizontal padding",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "hero_padding_top",
      "label": "Hero top padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "hero_padding_bottom",
      "label": "Hero bottom padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "bar_padding",
      "label": "Filter bar padding",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "calc_padding",
      "label": "Calculator section vertical padding",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "header",
      "content": "Power-Flow Capacity Calculator"
    },
    {
      "type": "checkbox",
      "id": "show_calculator",
      "label": "Show calculator block",
      "default": true
    },
    {
      "type": "text",
      "id": "calc_heading",
      "label": "Heading",
      "default": "Power-Flow Capacity Calculator"
    },
    {
      "type": "text",
