{%- liquid
  assign filter_blocks = section.blocks | where: 'type', 'filter'
  assign accent = section.settings.accent_color
  assign bg_image = section.settings.background_image
-%}

<div
  class="fss"
  id="fss-{{ section.id }}"
  data-search-url="{{ section.settings.search_url }}"
  style="
    --fss-accent: {{ accent }};
    --fss-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --fss-search-btn-color: {{ section.settings.search_btn_text_color }};
    --fss-search-btn-size: {{ section.settings.search_btn_font_size }}px;
    --fss-calc-btn-color: {{ section.settings.calc_btn_text_color }};
    --fss-calc-btn-size: {{ section.settings.calc_btn_font_size }}px;
    --fss-bar-padding: {{ section.settings.bar_padding }}px;
    --fss-btn-padding-x: {{ section.settings.btn_padding_x }}px;
    --fss-hero-padding-top: {{ section.settings.hero_padding_top }}px;
    --fss-hero-padding-bottom: {{ section.settings.hero_padding_bottom }}px;
    --fss-calc-padding: {{ section.settings.calc_padding }}px;
  "
>
  <div class="fss__hero">
    {%- if bg_image != blank -%}
      <img
        class="fss__hero-image"
        src="{{ bg_image | image_url: width: 2400 }}"
        srcset="{{ bg_image | image_url: width: 1200 }} 1200w, {{ bg_image | image_url: width: 1800 }} 1800w, {{ bg_image | image_url: width: 2400 }} 2400w"
        alt="{{ bg_image.alt | escape }}"
        loading="lazy"
        width="{{ bg_image.width }}"
        height="{{ bg_image.height }}"
      >
    {%- endif -%}
    <div class="fss__hero-overlay"></div>

    {%- if section.settings.heading != blank -%}
      <h2 class="fss__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="fss__bar">
      <div class="fss__fields">
        {%- for block in filter_blocks -%}
          {%- liquid
            assign options = block.settings.options | newline_to_br | strip_newlines | split: '<br />'
          -%}
          <div class="fss__field" {{ block.shopify_attributes }}>
            <select
              class="fss__select"
              data-filter-param="{{ block.settings.param | default: block.id }}"
              aria-label="{{ block.settings.label }}"
            >
              <option value="">{{ block.settings.label }}</option>
              {%- for option in options -%}
                {%- assign option = option | strip -%}
                {%- if option != blank -%}
                  <option value="{{ option }}">{{ option }}</option>
                {%- endif -%}
              {%- endfor -%}
            </select>
          </div>
        {%- endfor -%}
      </div>

      <div class="fss__actions">
        <button type="button" class="fss__search-btn" data-fss-search>
          {{ section.settings.search_label | default: 'Search' }}
        </button>
        <button type="button" class="fss__reset-btn" data-fss-reset aria-label="{{ section.settings.reset_label | default: 'Reset filters' }}">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 2v6h-6"></path>
            <path d="M3 12a9 9 0 0 1 15-6.7L21 8"></path>
            <path d="M3 22v-6h6"></path>
            <path d="M21 12a9 9 0 0 1-15 6.7L3 16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  {%- if section.settings.show_calculator -%}
    <div class="fss__calc">
      <div class="fss__calc-inner">
        {%- if section.settings.calc_heading != blank -%}
          <h2 class="fss__calc-heading">{{ section.settings.calc_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.calc_subheading != blank -%}
          <p class="fss__calc-subheading">{{ section.settings.calc_subheading }}</p>
        {%- endif -%}
        {%- if section.settings.calc_button_text != blank -%}
          <a href="{{ section.settings.calc_button_url | default: '/pages/fuel-pump-calculator' }}" class="fss__calc-btn">
            <span>{{ section.settings.calc_button_text }}</span>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
              <path d="M8 5l9 7-9 7V5z"></path>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  {%- endif -%}
</div>

<style>
  #fss-{{ section.id }} {
    --fss-accent: {{ accent }};
    font-family: inherit;
  }
  #fss-{{ section.id }} .fss__hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding: var(--fss-hero-padding-top, 48px) 20px var(--fss-hero-padding-bottom, 70px);
    overflow: hidden;
    background: #0a0a0a;
    min-height: 280px;
  }
  #fss-{{ section.id }} .fss__hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(35%);
    opacity: 0.55;
  }
  #fss-{{ section.id }} .fss__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.85) 100%);
    opacity: var(--fss-overlay, 0.8);
  }
  #fss-{{ section.id }} .fss__heading {
    position: relative;
    z-index: 2;
    color: var(--fss-accent);
    font-style: italic;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
    font-size: clamp(22px, 4vw, 34px);
    margin: 0 0 28px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.6);
  }
  #fss-{{ section.id }} .fss__bar {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1240px;
    background: #111111;
    border-radius: 4px;
    padding: var(--fss-bar-padding, 22px);
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  #fss-{{ section.id }} .fss__fields {
    flex: 1 1 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 12px;
  }
  #fss-{{ section.id }} .fss__select {
    width: 100%;
    height: 46px;
    padding: 0 14px;
    border: none;
    border-radius: 3px;
    background: #ffffff;
    color: #111111;
    font-size: 14px;
    font-weight: 600;
    appearance: none;
    -webkit-appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path d='M0 0l5 6 5-6z' fill='%23111'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    cursor: pointer;
  }
  #fss-{{ section.id }} .fss__actions {
    flex: 0 0 auto;
    display: flex;
    gap: 10px;
  }
  #fss-{{ section.id }} .fss__search-btn {
    height: 46px;
    padding: 0 var(--fss-btn-padding-x, 34px);
    background: var(--fss-accent);
    color: var(--fss-search-btn-color, #111111);
    border: none;
    border-radius: 3px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-size: var(--fss-search-btn-size, 14px);
    cursor: pointer;
    transition: filter 0.15s ease;
  }
  #fss-{{ section.id }} .fss__search-btn:hover {
    filter: brightness(1.08);
  }
  #fss-{{ section.id }} .fss__reset-btn {
    height: 46px;
    width: 46px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    color: var(--fss-accent);
    border: 1px solid var(--fss-accent);
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  #fss-{{ section.id }} .fss__reset-btn:hover {
    background: var(--fss-accent);
    color: #111111;
  }

  #fss-{{ section.id }} .fss__calc {
    background: #000000;
    text-align: center;
    padding: var(--fss-calc-padding, 70px) 20px;
  }
  #fss-{{ section.id }} .fss__calc-inner {
    max-width: 700px;
    margin: 0 auto;
  }
  #fss-{{ section.id }} .fss__calc-heading {
    color: var(--fss-accent);
    font-weight: 800;
    font-size: clamp(26px, 4vw, 40px);
    margin: 0 0 12px;
  }
  #fss-{{ section.id }} .fss__calc-subheading {
    color: #ffffff;
    font-size: 17px;
    margin: 0 0 30px;
    opacity: 0.9;
  }
  #fss-{{ section.id }} .fss__calc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--fss-accent);
    color: var(--fss-calc-btn-color, #111111);
    font-weight: 800;
    text-transform: none;
    padding: 16px var(--fss-btn-padding-x, 36px);
    border-radius: 6px;
    text-decoration: none;
    font-size: var(--fss-calc-btn-size, 17px);
    line-height: 1;
    transition: filter 0.15s ease, transform 0.15s ease;
  }
  #fss-{{ section.id }} .fss__calc-btn:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }

  @media only screen and (max-width: 47.5em) {
    #fss-{{ section.id }} .fss__bar {
      flex-direction: column;
    }
    #fss-{{ section.id }} .fss__actions {
      flex-direction: column;
    }
    #fss-{{ section.id }} .fss__search-btn,
    #fss-{{ section.id }} .fss__reset-btn {
      width: 100%;
    }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('fss-{{ section.id }}');
    if (!root) return;

    var searchBtn = root.querySelector('[data-fss-search]');
    var resetBtn = root.querySelector('[data-fss-reset]');
    var selects = root.querySelectorAll('.fss__select');
    var searchUrl = root.getAttribute('data-search-url') || '/search';

    if (searchBtn) {
      searchBtn.addEventListener('click', function () {
        var terms = [];
        selects.forEach(function (select) {
          if (select.value) {
            terms.push(select.value);
          }
        });
        if (!terms.length) return;
        var params = new URLSearchParams();
        params.set('q', terms.join(' '));
        params.set('type', 'product');
        window.location.href = searchUrl + '?' + params.toString();
      });
    }

    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        selects.forEach(function (select) {
          select.selectedIndex = 0;
        });
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Fuel system selector",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#f7c600"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Select Your Fuel System"
    },
    {
      "type": "url",
      "id": "search_url",
      "label": "Search results URL",
      "info": "Selected filter values are sent here as a native Shopify product search query (?q=...&type=product). Leave blank to use /search."
    },
    {
      "type": "text",
      "id": "search_label",
      "label": "Search button label",
      "default": "Search"
    },
    {
      "type": "text",
      "id": "reset_label",
      "label": "Reset button accessible label",
      "default": "Reset filters"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "color",
      "id": "search_btn_text_color",
      "label": "Search button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "search_btn_font_size",
      "label": "Search button text size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "calc_btn_text_color",
      "label": "Calculate button text color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "calc_btn_font_size",
      "label": "Calculate button text size",
      "min": 10,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "btn_padding_x",
      "label": "Button horizontal padding",
      "min": 10,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "hero_padding_top",
      "label": "Hero top padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "hero_padding_bottom",
      "label": "Hero bottom padding",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "bar_padding",
      "label": "Filter bar padding",
      "min": 5,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "calc_padding",
      "label": "Calculator section vertical padding",
      "min": 20,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 70
    },
    {
      "type": "header",
      "content": "Power-Flow Capacity Calculator"
    },
    {
      "type": "checkbox",
      "id": "show_calculator",
      "label": "Show calculator block",
      "default": true
    },
    {
      "type": "text",
      "id": "calc_heading",
      "label": "Heading",
      "default": "Power-Flow Capacity Calculator"
    },
    {
      "type": "text",
      "id": "calc_subheading",
      "label": "Subheading",
      "default": "Calculate flow rate required for given horsepower"
    },
    {
      "type": "text",
      "id": "calc_button_text",
      "label": "Button text",
      "default": "Calculate Now"
    },
    {
      "type": "url",
      "id": "calc_button_url",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "filter",
      "name": "Filter dropdown",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Fuel System"
        },
        {
          "type": "text",
          "id": "param",
          "label": "URL query parameter",
          "info": "e.g. fuel_system. Used to build the search URL.",
          "default": "filter"
        },
        {
          "type": "textarea",
          "id": "options",
          "label": "Options",
          "info": "One option per line.",
          "default": "Option 1\nOption 2\nOption 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Fuel system selector",
      "category": "Custom",
      "blocks": [
        {
          "type": "filter",
          "settings": {
            "label": "Fuel System",
            "param": "fuel_system",
            "options": "Carbureted\nEFI\nDiesel"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Application",
            "param": "application",
            "options": "Naturally Aspirated\nForced Induction"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Fuel Type",
            "param": "fuel_type",
            "options": "Gasoline\nE85\nDiesel\nMethanol"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Pump Location",
            "param": "pump_location",
            "options": "In-Tank\nExternal"
          }
        },
        {
          "type": "filter",
          "settings": {
            "label": "Horsepower",
            "param": "horsepower",
            "options": "0-1000\n1000-2000\n2000+"
          }
        }
      ]
    }
  ]
}
{% endschema %}
