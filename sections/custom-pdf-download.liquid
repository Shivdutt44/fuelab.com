<div class="pdf-download-section page-width">
  <div class="pdf-download-header">
    <h2 class="h1">{{ section.settings.heading }}</h2>
    <div class="heading-border"></div>
  </div>

  <div class="pdf-download-grid">
    {%- for block in section.blocks -%}
      {%- if block.settings.title != blank -%}
        <div class="pdf-download-item" {{ block.shopify_attributes }}>
          <a {% if block.settings.pdf_link != blank %}
               href="{{ block.settings.pdf_link }}" 
               data-pdf-url="{{ block.settings.pdf_link }}" 
               data-filename="{{ block.settings.title | handleize }}.pdf"
             {% else %}
               href="#" onclick="return false;"
             {% endif %} 
             class="pdf-download-link js-pdf-download">
            <span class="pdf-bullet"></span>
            <span class="pdf-text" title="{{ block.settings.title }}">{{ block.settings.title }}</span>
            <span class="pdf-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/>
              </svg>
            </span>
          </a>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<style>
.pdf-download-section {
  padding-top: 50px;
  padding-bottom: 50px;
  margin: 0 auto;
  max-width: 1200px;
  padding-left: 20px;
  padding-right: 20px;
}

.pdf-download-header {
  text-align: center;
  margin-bottom: 40px;
}

/* Xtra Theme ka default heading font aur weight inherit karega */
.pdf-download-header h2 {
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-bottom: 12px;
  margin-top: 0;
  color: inherit;
}

/* Yellow Accent Line */
.pdf-download-header .heading-border {
  width: 80px;
  height: 4px;
  background-color: #ffcc00; 
  margin: 0 auto;
}

/* 3 Column Desktop Grid Layout */
.pdf-download-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px 40px;
}

.pdf-download-item {
  display: flex;
  align-items: center;
  min-width: 0; /* Box break hone se rokne ke liye */
}

.pdf-download-link {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
  color: inherit; /* Theme text color mapping */
  font-size: 15px;
  transition: opacity 0.2s ease;
  width: 100%;
  cursor: pointer;
  min-width: 0; /* Flexbox text overflow control */
}

.pdf-download-link:hover {
  opacity: 0.7;
}

/* Solid Bullet Point */
.pdf-bullet {
  width: 8px;
  height: 8px;
  background-color: currentColor;
  border-radius: 50%;
  margin-right: 12px;
  flex-shrink: 0;
}

/* 1 Line strict rule text layout */
.pdf-text {
  line-height: 1.4;
  white-space: nowrap;      /* Text ko niche break hone se rokega */
  overflow: hidden;         /* Extra part ko chupaega */
  text-overflow: ellipsis;  /* Boht zyada lamba hone par aakhiri me (...) lagayega */
}

/* Download Icon Alignment - Text ke paas */
.pdf-icon {
  margin-left: 8px; /* Text se sate rehne ke liye gap */
  display: inline-flex;
  align-items: center;
  flex-shrink: 0; /* Icon kabhi chota ya compress nahi hoga */
}

.pdf-icon svg {
  width: 15px;
  height: 15px;
  fill: currentColor;
}

/* --- Fully Responsive Breakpoints --- */

/* Tablets / iPads Layout: 2 Columns */
@media screen and (max-width: 989px) {
  .pdf-download-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px 30px;
  }
}

/* Mobile Devices Layout: 1 Column */
@media screen and (max-width: 749px) {
  .pdf-download-grid {
    grid-template-columns: 1fr;
    gap: 15px;
  }
  .pdf-download-section {
    padding-top: 30px;
    padding-bottom: 30px;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const downloadLinks = document.querySelectorAll('.js-pdf-download');
  
  downloadLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      const url = this.getAttribute('data-pdf-url');
      const filename = this.getAttribute('data-filename');
      
      if (!url || url === '#' || window.Shopify.designMode) {
        return;
      }
      
      e.preventDefault();
      
      fetch(url)
        .then(response => response.blob())
        .then(blob => {
          const blobUrl = window.URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.style.display = 'none';
          a.href = blobUrl;
          a.download = filename || 'document.pdf';
          document.body.appendChild(a);
          a.click();
          window.URL.revokeObjectURL(blobUrl);
          document.body.removeChild(a);
        })
        .catch(err => {
          window.open(url, '_blank');
        });
    });
  });
});
</script>

{% schema %}
{
  "name": "PDF Download Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DOWNLOAD"
    }
  ],
  "blocks": [
    {
      "type": "pdf_item",
      "name": "PDF Item",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Document Name",
          "default": "Model 14601 Diaphragm Replacement Kit"
        },
        {
          "type": "url",
          "id": "pdf_link",
          "label": "Upload/Link PDF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDF Download Grid",
      "blocks": [
        { "type": "pdf_item" },
        { "type": "pdf_item" },
        { "type": "pdf_item" }
      ]
    }
  ]
}
{% endschema %}