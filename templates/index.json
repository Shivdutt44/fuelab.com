        "text_9ELpAf": {
          "type": "text",
          "settings": {
            "faq_question": "<strong>Are FUELAB products suitable for both street and race applications?</strong>",
            "icon": "none",
            "header_image_svg": "",
            "header_image_width": 25,
            "faq_answer": "<p>Yes. FUELAB designs fuel delivery solutions for a wide range of applications, including street performance, motorsports, off-road vehicles, and diesel performance. Product specifications will indicate the intended use and compatibility.</p>",
